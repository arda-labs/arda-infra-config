# ─────────────────────────────────────────────────────────────
#  Arda Platform — Example Environment Variables
#  Copy to `.env` and fill in real values for your environment.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=arda_central

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<change-me>

# ── APISIX ───────────────────────────────────────────────────
APISIX_ADMIN_KEY=<generate-random-hex-32>

# ── Keycloak Gateway Client ──────────────────────────────────
KEYCLOAK_GW_CLIENT_SECRET=<change-me>

# ── Migration Worker ─────────────────────────────────────────
MIGRATION_WORKER_KC_CLIENT_SECRET=<change-me>

# ── Notification Service ─────────────────────────────────────
NOTIFICATION_KC_CLIENT_SECRET=<change-me>

# ── Super Admin (Keycloak user for dev/testing) ──────────────
SUPER_ADMIN_PASSWORD=<change-me>
